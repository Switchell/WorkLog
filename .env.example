# Скопируйте в .env и заполните. Файл .env в git не коммитьте.

# PostgreSQL. Для admin/client в Docker compose всё равно подставит DB_HOST=db (перекрывает .env).
# С хоста / без Docker: localhost или 127.0.0.1
DB_HOST=db
DB_PORT=5432
DB_USER=user
# Для уже созданного тома postgres чаще всего совпадает с тем, что был при первом запуске (см. CONTRIBUTING.md)
DB_PASSWORD=password
DB_NAME=workday_db

# Grafana (http://localhost:3001) — пароль admin задаётся только при первом создании тома grafana_data
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=admin
# GRAFANA_ROOT_URL=http://localhost:3001/
# GRAFANA_DEFAULT_THEME=dark

# Опционально: пул соединений SQLAlchemy
# DB_POOL_SIZE=8
# DB_MAX_OVERFLOW=12

# Telegram (с сервера без доступа к api.telegram.org нужен VPN или прокси)
TG_TOKEN=123456:ABC-DEF...
TG_ADMIN_ID=123456789
# TG_CONNECT_TIMEOUT=20
# TG_READ_TIMEOUT=90
# TG_SEND_RETRIES=4

# Клиентский портал (/client)
# AXIS_CLIENT_KWORK_PASSWORD=
# AXIS_CLIENT_FREELANCE_PASSWORD=
# В проде: заполнить оба и выставить AXIS_ALLOW_DEFAULT_CLIENT_PASSWORDS=0
AXIS_ALLOW_DEFAULT_CLIENT_PASSWORDS=1

# Доп. пользователи админки: login:bcrypt_hash:role через ;
# ADDITIONAL_USERS=

# Лог ошибок приложения
# LOG_FILE=axis_errors.log
